# ============================================
# AI Orchestrator — Environment Configuration
# ============================================

# --- Default LLM (fallback if per-agent not set) ---
# Любой OpenAI-совместимый провайдер: Z.AI, OpenRouter, vsellm и т.д.
DEFAULT_MODEL=glm-5.2
DEFAULT_PROVIDER=zai
DEFAULT_API_KEY=your_zai_api_key_here
# DEFAULT_BASE_URL=https://api.z.ai/api/coding/paas/v4

# --- Per-agent LLM override (optional) ---
# Uncomment to use different model/provider per agent.
# PROVIDERS: zai, openai, anthropic
#
# RESEARCHER_MODEL=glm-5.2
# RESEARCHER_PROVIDER=zai
# RESEARCHER_API_KEY=
# RESEARCHER_TEMPERATURE=0.3
#
# PROGRAMMER_MODEL=glm-5.2
# PROGRAMMER_PROVIDER=zai
# PROGRAMMER_API_KEY=
# PROGRAMMER_TEMPERATURE=0.0
#
# DEBUGGER_MODEL=glm-5.2
# DEBUGGER_PROVIDER=zai
# DEBUGGER_API_KEY=
# DEBUGGER_TEMPERATURE=0.0
#
# VALIDATOR_MODEL=glm-5.2
# VALIDATOR_PROVIDER=zai
# VALIDATOR_API_KEY=
# VALIDATOR_TEMPERATURE=0.0
#
# REPORTER_MODEL=glm-5.2
# REPORTER_PROVIDER=zai
# REPORTER_API_KEY=
# REPORTER_TEMPERATURE=0.0

# --- Mattermost ---
MATTERMOST_BOT_TOKEN=your_mattermost_bot_token_here
MATTERMOST_TEAM_NAME=ai-engineering-factory
# MATTERMOST_URL=http://127.0.0.1:8065
